# SkyFi Remote MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required (single-tenant / local) ─────────────────────────────────────────
# For multi-user deployment: leave unset or use as fallback; clients send X-Skyfi-Api-Key header.
X_SKYFI_API_KEY=your-skyfi-api-key-here
# Use the base URL from SkyFi docs (api.skyfi.com does not resolve; use platform API)
SKYFI_API_BASE_URL=https://app.skyfi.com/platform-api

# ── Pagination ──────────────────────────────────────────────────────────────
ARCHIVES_PAGE_SIZE=100

# ── Feasibility Polling ─────────────────────────────────────────────────────
FEASIBILITY_POLL_INTERVAL_BASE=10
FEASIBILITY_POLL_BACKOFF_FACTOR=2
FEASIBILITY_POLL_MAX_INTERVAL=60
FEASIBILITY_POLL_TIMEOUT=300

# ── Imagery Rules ───────────────────────────────────────────────────────────
# Suggest SAR imagery when optical cloud coverage >= this threshold (percent)
SAR_SUGGESTION_CLOUD_THRESHOLD=60

# ── Rate Limiting & Observability (Phase 6) ─────────────────────────────────
# Inbound rate limit per client IP (requests/minute). 0 = disabled.
# We default to 0 for self-hosted (single user, local Docker); no benefit to limiting
# the user's own agent. Set when you host for multiple clients (e.g. RATE_LIMIT_PER_MINUTE=100).
# RATE_LIMIT_PER_MINUTE=0
# Cache TTL in seconds (default 300 = 5 min)
# PRICING_CACHE_TTL_SECONDS=300
# PASS_PREDICTION_CACHE_TTL_SECONDS=300

# ── AOI Validation ──────────────────────────────────────────────────────────
AOI_MAX_VERTICES=500
AOI_MAX_AREA_SQKM=500000

# ── Order Safety ────────────────────────────────────────────────────────────
ORDER_PREVIEW_TTL_SECONDS=600
# Tasking AOI area must be within this range (sq km); SkyFi typical 25–500
TASKING_MIN_AREA_SQKM=25
TASKING_MAX_AREA_SQKM=500

# ── HTTP Client ────────────────────────────────────────────────────────────
# SKYFI_REQUEST_TIMEOUT=30
# SKYFI_RETRY_COUNT=3

# ── Logging ────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── MCP Server ─────────────────────────────────────────────────────────────
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# ── Download tools (download_order_file, download_recent_orders) ─────────────
# When set, MCP download tools may only write under this directory (e.g. Docker: mount host folder and set this).
# Local server: optional; omit to allow any path (e.g. ~/Downloads). Docker: set to container path of mounted volume.
# SKYFI_DOWNLOAD_DIR=/downloads

# ── AOI Monitoring (Phase 5) ───────────────────────────────────────────────
# Full URL where SkyFi POSTs events (our route is /webhooks/skyfi). Optional if the server can derive it (see below).
#   Local: use a Cloudflare tunnel (cloudflared) to port 8000, then set this to the tunnel URL + /webhooks/skyfi. See docs/webhook-setup.md.
#   Cloud: set to your deployed app URL, e.g. https://your-app.example.com/webhooks/skyfi.
#   Auto-derived: when the client connects via a public URL (e.g. https://your-mcp.com/mcp), the server can derive the webhook as that host + /webhooks/skyfi. For localhost the server cannot derive a public URL; set this or MCP_PUBLIC_URL.
# SKYFI_WEBHOOK_BASE_URL=https://your-tunnel-or-app.example.com/webhooks/skyfi
# Optional: public base URL of this server (e.g. https://your-app.railway.app). Used to derive webhook URL when SKYFI_WEBHOOK_BASE_URL is not set. Some platforms set PUBLIC_URL automatically.
# MCP_PUBLIC_URL=https://your-app.example.com
# Optional: default URL we POST SkyFi events to (e.g. Slack incoming webhook). Used when notification_url is not passed and X-Skyfi-Notification-Url header is not set. Clients can send the header instead (no server env needed).
# SKYFI_NOTIFICATION_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX
# Max AOI monitoring events to keep in memory for get_monitoring_events (default 100)
# MONITORING_EVENTS_MAX=100
